{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./js",
        "sourceMap": true,
        "allowJs": true,
        "checkJs": false,
        "moduleResolution": "node"
    },
    "include": [
        "js/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}