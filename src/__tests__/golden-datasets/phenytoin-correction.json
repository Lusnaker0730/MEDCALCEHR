{
  "calculatorId": "phenytoin-correction",
  "calculatorName": "Phenytoin (Dilantin) Correction",
  "version": "2.0",
  "calculatorType": "simple",
  "cases": [
    {
      "id": "GD-PHENY-001",
      "description": "Normal albumin (>3.2 g/dL) - no correction needed, returns measured value",
      "source": "Albumin 4.4 g/dL > 3.2 g/dL threshold → no correction needed, return measured = 12.0",
      "inputs": {
        "pheny-total": 12,
        "pheny-albumin": 4.4,
        "pheny-renal": "no"
      },
      "expected": [
        {
          "label": "Corrected Phenytoin",
          "value": 12.0,
          "unit": "mcg/mL",
          "tolerance": 0.2
        }
      ]
    },
    {
      "id": "GD-PHENY-002",
      "description": "Low albumin, no renal failure - level adjusted upward",
      "source": "Corrected = 8 / (0.275 * 2.0 + 0.1) = 8 / 0.65 = 12.3",
      "inputs": {
        "pheny-total": 8,
        "pheny-albumin": 2.0,
        "pheny-renal": "no"
      },
      "expected": [
        {
          "label": "Corrected Phenytoin",
          "value": 12.3,
          "unit": "mcg/mL",
          "tolerance": 0.2
        }
      ]
    },
    {
      "id": "GD-PHENY-003",
      "description": "Low albumin with CrCl <20 mL/min (renal failure, adjustment=0.2)",
      "source": "Corrected = 8 / (0.2 * 2.0 + 0.1) = 8 / 0.5 = 16.0",
      "inputs": {
        "pheny-total": 8,
        "pheny-albumin": 2.0,
        "pheny-renal": "yes"
      },
      "expected": [
        {
          "label": "Corrected Phenytoin",
          "value": 16.0,
          "unit": "mcg/mL",
          "tolerance": 0.2
        }
      ]
    },
    {
      "id": "GD-PHENY-004",
      "description": "Subtherapeutic corrected level",
      "source": "Corrected = 5 / (0.275 * 3.0 + 0.1) = 5 / 0.925 = 5.4",
      "inputs": {
        "pheny-total": 5,
        "pheny-albumin": 3.0,
        "pheny-renal": "no"
      },
      "expected": [
        {
          "label": "Corrected Phenytoin",
          "value": 5.4,
          "unit": "mcg/mL",
          "tolerance": 0.2
        }
      ]
    },
    {
      "id": "GD-PHENY-005",
      "description": "Upper therapeutic range corrected level",
      "source": "Corrected = 15 / (0.275 * 2.5 + 0.1) = 15 / 0.7875 = 19.0",
      "inputs": {
        "pheny-total": 15,
        "pheny-albumin": 2.5,
        "pheny-renal": "no"
      },
      "expected": [
        {
          "label": "Corrected Phenytoin",
          "value": 19.0,
          "unit": "mcg/mL",
          "tolerance": 0.3
        }
      ]
    }
  ]
}